{
  "name": "@sawcode/agent",
  "version": "0.1.0",
  "description": "Claude Code Agent/Skill built with Bun + TypeScript",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./sdk": {
      "import": "./dist/sdk.js",
      "types": "./dist/sdk.d.ts"
    }
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "tsc --outDir dist",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "tui": "bun src/cli.ts tui",
    "query": "bun src/cli.ts query",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "example": "bun run examples/simple-agent.ts",
    "example:kilocode": "bun run examples/kilocode-agent.ts",
    "clean": "rm -rf dist node_modules bun.lock"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@modelcontextprotocol/sdk": "^1.4.0",
    "boxen": "5.1.2",
    "chalk": "4.1.2",
    "cli-spinners": "2.6.1",
    "dotenv": "^16.3.1",
    "figures": "^6.1.0",
    "ink": "^6.8.0",
    "ink-divider": "^4.1.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "log-update": "4.0.0",
    "react": "^19.2.4",
    "terminal-size": "^4.0.1",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@types/bun": "latest",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.3.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
