# SawCode Agent Configuration Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to git - it contains secrets!

# ─────────────────────────────────────────────────
# Claude API Configuration
# ─────────────────────────────────────────────────

# Your Anthropic API key
# Get it from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# Model to use (examples below)
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ─────────────────────────────────────────────────
# Agent Settings
# ─────────────────────────────────────────────────

# Temperature (0-1): 0=deterministic, 1=creative
AGENT_TEMPERATURE=0.7

# Maximum tokens per response
AGENT_MAX_TOKENS=4096

# ─────────────────────────────────────────────────
# TUI Settings
# ─────────────────────────────────────────────────

TUI_PROMPT=🤖 SawCode>
TUI_SHOW_WELCOME=true
TUI_SHOW_HELP=true

# ─────────────────────────────────────────────────
# Tools
# ─────────────────────────────────────────────────

ENABLE_BASH_TOOL=true
ENABLE_WEBFETCH_TOOL=true
BASH_TIMEOUT=30000
HTTP_TIMEOUT=5000

# ─────────────────────────────────────────────────
# Development
# ─────────────────────────────────────────────────

NODE_ENV=development
DEBUG=sawcode:*
VERBOSE=false

# ─────────────────────────────────────────────────
# State Management
# ─────────────────────────────────────────────────

STATE_DIR=./state
AUTO_SAVE_INTERVAL=0

# ─────────────────────────────────────────────────
# KiloCode API (Optional Alternative)
# ─────────────────────────────────────────────────

KILOCODE_API_URL=https://api.kilocode.com
KILOCODE_TOKEN=
KILOCODE_MODEL=
KILOCODE_USER_ID=

# Model to use (default: claude-opus-4-6)
CLAUDE_MODEL=claude-opus-4-6

# ============================================================================
# Agent Configuration
# ============================================================================

# Default temperature (0.0 - 1.0)
AGENT_TEMPERATURE=0.7

# Default max tokens
AGENT_MAX_TOKENS=2048

# System prompt for the agent
AGENT_SYSTEM_PROMPT=You are a helpful AI assistant.

# ============================================================================
# TUI Configuration
# ============================================================================

# Custom prompt for TUI
TUI_PROMPT=🤖 SawCode>

# Show welcome banner
TUI_SHOW_WELCOME=true

# Show help on startup
TUI_SHOW_HELP=true

# Max history lines
TUI_MAX_HISTORY=100

# ============================================================================
# Tool Configuration
# ============================================================================

# Enable bash tool
ENABLE_BASH_TOOL=true

# Enable webfetch tool
ENABLE_WEBFETCH_TOOL=true

# Bash command timeout (ms)
BASH_TIMEOUT=30000

# HTTP request timeout (ms)
HTTP_TIMEOUT=5000

# ============================================================================
# Development & Debugging
# ============================================================================

# Debug mode
DEBUG=sawcode:*

# Node environment
NODE_ENV=development

# Verbose logging
VERBOSE=false

# ============================================================================
# Storage & Persistence
# ============================================================================

# Directory for saving agent state
STATE_DIR=./state

# Auto-save state interval (ms, 0 = disabled)
AUTO_SAVE_INTERVAL=0

# ============================================================================
# KiloCode API Provider
# ============================================================================

# KiloCode API base URL (default: https://api.kilocode.com)
KILOCODE_API_URL=https://api.kilocode.com

# KiloCode User ID (optional, extracted from token if not set)
KILOCODE_USER_ID=your-user-id-here

# KiloCode Bearer Token (for authentication)
# This is the JWT token provided by KiloCode
KILOCODE_TOKEN=your-token-here

# Alternative: KiloCode API Key (if using API key authentication)
# KILOCODE_API_KEY=your-api-key-here
